/**
 * End-to-end tests for complete document workflow
 * Tests the full user journey from login to document processing
 */

import { test, expect } from '@playwright/test'

test.describe('PDF Searcher Document Workflow', () => {
  test.beforeEach(async ({ page }) => {
    // Navigate to the application
    await page.goto('/')
  })

  test('should complete full document upload and processing workflow', async ({ page }) => {
    // Step 1: Login/Authentication - OAuth flow (manual step in real test)
    await page.click('[data-testid="login-button"]')
    // Note: In real E2E testing, OAuth would redirect to Google/GitHub
    // For this test, we assume user completes OAuth and gets redirected back
    
    // Wait for dashboard to load after OAuth redirect
    await expect(page.locator('[data-testid="dashboard"]')).toBeVisible()

    // Step 2: Upload form is already visible on dashboard
    await expect(page.locator('[data-testid="upload-form"]')).toBeVisible()

    // Step 3: Upload document
    const fileInput = page.locator('[data-testid="file-input"]')
    await fileInput.setInputFiles('./tests/fixtures/sample-document.pdf')

    // Step 4: Fill metadata form - these are SearchableSelect components
    await page.click('[data-testid="law-firm-select"]')
    await page.getByText('Skadden, Arps, Slate, Meagher & Flom LLP').click()
    
    await page.click('[data-testid="fund-manager-select"]')
    await page.getByText('Blackstone').click()
    
    await page.click('[data-testid="fund-admin-select"]')
    await page.getByText('Standish').click()
    
    await page.click('[data-testid="jurisdiction-select"]')
    await page.getByText('Delaware').click()

    // Verify dropdowns show selected values (SearchableSelect shows selected text)
    await expect(page.locator('[data-testid="law-firm-select"]')).toContainText('Skadden')
    await expect(page.locator('[data-testid="fund-manager-select"]')).toContainText('Blackstone')
    await expect(page.locator('[data-testid="fund-admin-select"]')).toContainText('Standish')
    await expect(page.locator('[data-testid="jurisdiction-select"]')).toContainText('Delaware')

    // Step 5: Submit upload
    await page.click('[data-testid="upload-submit-button"]')
    
    // Wait for upload to complete (button should change text)
    await expect(page.locator('[data-testid="upload-submit-button"]')).toContainText('Processing', { timeout: 5000 })

    // Step 6: Document list is on the same dashboard page
    // Step 7: Verify document appears in enhanced document list
    await expect(page.locator('[data-testid="dashboard"]')).toBeVisible()
    
    // Wait for document to appear (may take a moment)
    await page.waitForSelector('[data-testid="document-item"]', { timeout: 10000 })
    
    const documentItem = page.locator('[data-testid="document-item"]').first()
    await expect(documentItem).toBeVisible()
    
    // Verify document status shows processing
    const statusBadge = documentItem.locator('[data-testid="document-status"]')
    await expect(statusBadge).toContainText(/processing|queued|pending/)

    // Step 8: Wait for processing to complete (or timeout in reasonable time)
    await page.waitForFunction(() => {
      const status = document.querySelector('[data-testid="document-status"]')?.textContent
      return status?.includes('completed') || status?.includes('ready')
    }, { timeout: 60000 }) // 1 minute timeout for processing

    // Step 9: Verify completed document
    await expect(statusBadge).toContainText(/completed|ready/)

    // Step 10: Click on document to view details
    await documentItem.click()
    
    // Wait for document details page (documents/[id] route)
    await expect(page).toHaveURL(/\/documents\/\d+/)
    
    // Verify document content is displayed
    await expect(page.locator('h1')).toBeVisible() // Document title
    await expect(page.locator('text=Processing Status')).toBeVisible() // Status section
  })

  test('should handle similarity search functionality', async ({ page }) => {
    // Login first - OAuth flow
    await page.click('[data-testid="login-button"]')
    await expect(page.locator('[data-testid="dashboard"]')).toBeVisible()

    // Upload a document first to have something to search against
    const fileInput = page.locator('[data-testid="file-input"]')
    await fileInput.setInputFiles('./tests/fixtures/sample-document.pdf')

    // Fill metadata and upload
    await page.click('[data-testid="law-firm-select"]')
    await page.getByText('Skadden, Arps, Slate, Meagher & Flom LLP').click()
    await page.click('[data-testid="fund-manager-select"]')
    await page.getByText('Blackstone').click()
    await page.click('[data-testid="fund-admin-select"]')
    await page.getByText('Standish').click()
    await page.click('[data-testid="jurisdiction-select"]')
    await page.getByText('Delaware').click()
    
    await page.click('[data-testid="upload-submit-button"]')
    // Wait for upload processing to start
    await expect(page.locator('[data-testid="upload-submit-button"]')).toContainText('Processing', { timeout: 5000 })

    // Wait for document to appear in list
    await page.waitForSelector('[data-testid="document-item"]', { timeout: 10000 })
    
    // Click on document to go to similarity search
    await page.locator('[data-testid="document-item"]').first().click()
    
    // Should navigate to document details page
    await expect(page).toHaveURL(/\/documents\/\d+/)
    
    // Look for similarity search functionality on the document page
    await expect(page.locator('text=Similar Documents')).toBeVisible({ timeout: 10000 })
  }

  test('should handle batch processing mode for multiple documents', async ({ page }) => {
    // Login - OAuth flow
    await page.click('[data-testid="login-button"]')
    await expect(page.locator('[data-testid="dashboard"]')).toBeVisible()

    // Upload multiple documents from dashboard
    const documentCount = 3 // Reduced for test performance
    
    for (let i = 0; i < documentCount; i++) {
      // Upload document (form is on dashboard)
      const fileInput = page.locator('[data-testid="file-input"]')
      await fileInput.setInputFiles('./tests/fixtures/sample-document.pdf')

      // Fill metadata for each document
      await page.click('[data-testid="law-firm-select"]')
      await page.getByText('Skadden, Arps, Slate, Meagher & Flom LLP').click()
      await page.click('[data-testid="fund-manager-select"]')
      await page.getByText('Blackstone').click()
      await page.click('[data-testid="fund-admin-select"]')
      await page.getByText('Standish').click()
      await page.click('[data-testid="jurisdiction-select"]')
      await page.getByText('Delaware').click()

      // Submit upload
      await page.click('[data-testid="upload-submit-button"]')
      await expect(page.locator('[data-testid="upload-success-message"]')).toBeVisible()
      
      // Wait a moment before next upload
      await page.waitForTimeout(1000)
    }

    // Verify all documents appear in enhanced document list
    await expect(page.locator('[data-testid="document-item"]')).toHaveCount(documentCount, { timeout: 15000 })

    // Wait for documents to process (batch mode should handle efficiently)
    await page.waitForFunction((count) => {
      const completedItems = document.querySelectorAll('[data-testid="document-status"]')
      return Array.from(completedItems).filter(item => 
        item.textContent?.includes('completed') || item.textContent?.includes('ready') || item.textContent?.includes('processed')
      ).length >= count
    }, documentCount, { timeout: 120000 }) // 2 minutes for batch processing

    // Verify all documents completed processing
    const statusElements = page.locator('[data-testid="document-status"]')
    for (let i = 0; i < documentCount; i++) {
      await expect(statusElements.nth(i)).toContainText(/completed|ready|processed/)
    }
  })

  test('should handle document processing errors gracefully', async ({ page }) => {
    // Login - OAuth flow
    await page.click('[data-testid="login-button"]')
    await expect(page.locator('[data-testid="dashboard"]')).toBeVisible()

    // Try to upload invalid file type - the upload form is on dashboard
    await expect(page.locator('[data-testid="upload-form"]')).toBeVisible()

    const fileInput = page.locator('[data-testid="file-input"]')
    await fileInput.setInputFiles('./tests/fixtures/invalid-file.txt')

    // The app should filter out non-PDF files automatically
    // Listen for alert dialog about invalid files
    let alertShown = false
    page.on('dialog', async dialog => {
      if (dialog.message().includes('Only PDF files are allowed')) {
        alertShown = true
        await dialog.accept()
      }
    })

    // Wait a moment for file processing and potential alert
    await page.waitForTimeout(1000)

    // The upload button should remain disabled if no valid files
    const uploadButton = page.locator('[data-testid="upload-submit-button"]')
    await expect(uploadButton).toBeDisabled()
  }

  test('should maintain UI responsiveness during interactions', async ({ page }) => {
    // Login - OAuth flow
    await page.click('[data-testid="login-button"]')
    await expect(page.locator('[data-testid="dashboard"]')).toBeVisible()

    // Simulate rapid interactions on the dashboard
    for (let i = 0; i < 5; i++) {
      // Interact with upload form
      await expect(page.locator('[data-testid="upload-form"]')).toBeVisible()
      
      // Click file input (without actually selecting file)
      await page.locator('[data-testid="file-input"]').hover()
      
      // Test dropdown interactions
      await page.click('[data-testid="law-firm-select"]')
      await page.press('body', 'Escape') // Close dropdown
      
      await page.click('[data-testid="fund-manager-select"]')
      await page.press('body', 'Escape') // Close dropdown
      
      // Verify dashboard remains responsive
      await expect(page.locator('[data-testid="dashboard"]')).toBeVisible()
      
      // Small delay to prevent overwhelming the UI
      await page.waitForTimeout(100)
    }

    // UI should remain responsive
    await expect(page.locator('[data-testid="dashboard"]')).toBeVisible()
    await expect(page.locator('[data-testid="upload-form"]')).toBeVisible()
  }

  test('should handle network interruptions gracefully', async ({ page }) => {
    // Login - OAuth flow
    await page.click('[data-testid="login-button"]')
    await expect(page.locator('[data-testid="dashboard"]')).toBeVisible()

    // Start document upload from dashboard
    const fileInput = page.locator('[data-testid="file-input"]')
    await fileInput.setInputFiles('./tests/fixtures/sample-document.pdf')

    // Fill metadata
    await page.click('[data-testid="law-firm-select"]')
    await page.getByText('Skadden, Arps, Slate, Meagher & Flom LLP').click()
    await page.click('[data-testid="fund-manager-select"]')
    await page.getByText('Blackstone').click()
    await page.click('[data-testid="fund-admin-select"]')
    await page.getByText('Standish').click()
    await page.click('[data-testid="jurisdiction-select"]')
    await page.getByText('Delaware').click()

    // Simulate slow network during upload
    await page.route('**/api/documents/upload', route => {
      // Delay to simulate slow network, then let it through
      setTimeout(() => route.continue(), 3000)
    })

    await page.click('[data-testid="upload-submit-button"]')
    
    // Should show processing state in button text
    await expect(page.locator('[data-testid="upload-submit-button"]')).toContainText('Processing')
    
    // Should eventually complete or show error in button text
    await expect(
      page.locator('[data-testid="upload-submit-button"]')
    ).not.toContainText('Processing', { timeout: 30000 })
  }

  test('should handle browser refresh during processing', async ({ page, context }) => {
    // Login - OAuth flow
    await page.click('[data-testid="login-button"]')
    await expect(page.locator('[data-testid="dashboard"]')).toBeVisible()

    // Upload document from dashboard
    const fileInput = page.locator('[data-testid="file-input"]')
    await fileInput.setInputFiles('./tests/fixtures/sample-document.pdf')

    await page.click('[data-testid="law-firm-select"]')
    await page.getByText('Skadden, Arps, Slate, Meagher & Flom LLP').click()
    await page.click('[data-testid="fund-manager-select"]')
    await page.getByText('Blackstone').click()
    await page.click('[data-testid="fund-admin-select"]')
    await page.getByText('Standish').click()
    await page.click('[data-testid="jurisdiction-select"]')
    await page.getByText('Delaware').click()

    await page.click('[data-testid="upload-submit-button"]')
    // Wait for upload processing to start
    await expect(page.locator('[data-testid="upload-submit-button"]')).toContainText('Processing', { timeout: 5000 })
    
    // Wait for document to appear in enhanced document list
    await expect(page.locator('[data-testid="document-item"]')).toBeVisible()

    // Refresh browser
    await page.reload()
    
    // Should still be logged in and see documents (OAuth session persists)
    await expect(page.locator('[data-testid="dashboard"]')).toBeVisible()
    await expect(page.locator('[data-testid="document-item"]')).toBeVisible()
    
    // Document status should be preserved
    const statusBadge = page.locator('[data-testid="document-status"]').first()
    await expect(statusBadge).toBeVisible()
  }
})